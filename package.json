{
  "name": "smdr-insight",
  "version": "0.1.0",
  "description": "SMDR Insight - modern MiVoice Business SMDR web application",
  "author": "elmertech.work",
  "homepage": "https://github.com/gabaelmer/Project-SMDR",
  "repository": {
    "type": "git",
    "url": "https://github.com/gabaelmer/Project-SMDR.git"
  },
  "main": "dist/main/main/node-server.js",
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "dev": "npm run rebuild:native && concurrently -k \"npm:dev:renderer\" \"npm:dev:main\" \"npm:dev:server\"",
    "dev:renderer": "vite --config renderer/vite.config.ts",
    "dev:main": "tsc -p main/tsconfig.json --watch",
    "dev:server": "wait-on tcp:5173 && cross-env SMDR_PORT=61593 VITE_DEV_SERVER_URL=http://localhost:5173 node dist/main/main/node-server.js",
    "build": "npm run clean && npm run build:renderer && npm run build:main",
    "build:renderer": "vite build --config renderer/vite.config.ts",
    "build:main": "tsc -p main/tsconfig.json",
    "serve": "npm run build && node dist/main/main/node-server.js",
    "serve:node": "cross-env SMDR_PORT=61593 node dist/main/main/node-server.js",
    "start": "node dist/main/main/node-server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "simulate:stream": "node --import tsx backend/simulator/mock-smdr-stream.ts",
    "simulate:failover": "node --import tsx scripts/failover-simulation.ts",
    "test:load": "node --import tsx scripts/load-test.ts",
    "test:memory": "node --import tsx scripts/memory-leak-test.ts",
    "test:all": "./scripts/debug-and-test.sh",
    "rebuild:native": "npm rebuild better-sqlite3",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\""
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "better-sqlite3": "^11.8.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "dayjs": "^1.11.13",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "morgan": "^1.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.15.1",
    "uuid": "^11.1.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.13.9",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.2",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "vitest": "^3.0.7"
  }
}
